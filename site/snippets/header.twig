<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }} – {{ site.title }}</title>

  <!-- Shared CSS / JS -->
  {% set viteInstance = vite() %}
  {{ viteInstance.css('index.css')|raw }}
  {{ viteInstance.js('index.js', {'defer': true})|raw }}

  <!-- Per-page CSS / JS (loaded only when present) -->
  {% set templateName = page.template %}
  {% set pageCss = viteInstance.css("templates/#{templateName}.css", [], true) %}
  {% set pageJs = viteInstance.js("templates/#{templateName}.js", {'defer': true}, true) %}
  {% if pageCss %}
    {{ pageCss|raw }}
  {% endif %}
  {% if pageJs %}
    {{ pageJs|raw }}
  {% endif %}
</head>

<body>
  {% include '@snippets/menu.twig' %}